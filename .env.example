# Frontend (Next.js) — local dev points to the Express backend on port 4040
NEXT_PUBLIC_API_URL=http://localhost:4040

# Backend (Express / Vercel serverless)
# On Vercel, set NEXT_PUBLIC_API_URL to your deployment URL, e.g. https://your-app.vercel.app
PORT=4040
PARENT_FOLDER_ID=your_google_drive_parent_folder_id
MONGODB_URL=your_mongodb_connection_string
